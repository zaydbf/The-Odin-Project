<h1>Find a flight</h1>
<%= form_with url: flights_path, method: :get do |f| %>
    <div>
        <%= f.label :departure_airport_id, "From:" %>
        <%= f.select :departure_airport_id, options_for_select(@airports, params[:departure_airport_id]), prompt: "Select Departure" %>
    </div>

    <div>
        <%= f.label :arrival_airport_id, "To:" %>
        <%= f.select :arrival_airport_id, options_for_select(@airports, params[:arrival_airport_id]), prompt: "Select Arrival" %>
    </div>

    <div>
        <%= f.label :passengers, "Passengers:" %>
        <%= f.select :passengers, options_for_select((1..4).to_a, params[:passengers]) %>
    </div>

    <div>
        <%= f.label :flight_date, "Date:" %>
        <%= f.select :flight_date, options_for_select(@flight_dates, params[:flight_date]), prompt: "Select Date" %>
    </div>

    <%= f.submit "Search Flights" %>
<% end %>

<h2>Available Flights</h2>
<% if @flights.any? %>

  <%= form_with url: new_booking_path, method: :get do |f| %>
    <%= hidden_field_tag :passengers, params[:passengers] %>
    <ul>
      <% @flights.each do |flight| %>
        <li>
          <label>
            <%= f.radio_button :flight_id, flight.id, required: true %>
            <strong><%= flight.departure_airport.code %></strong> to 
            <strong><%= flight.arrival_airport.code %></strong> | 
            Departs: <%= flight.departure_time.strftime("%B %d, %Y at %I:%M %p") %> | 
            Duration: <%= flight.duration %> mins
          </label>
        </li>
      <% end %>
    </ul>

    <%= f.submit "Select Flight & Continue", class: "btn-booking" %>
  <% end %>

<% elsif params[:departure_airport_id].present? %>
    <p>No flights Found</p>
<% else %>
    <p>Enter your travel details above to search for flights</p>
<% end %>
